# ─── macOS ──────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ─── Windows ────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ─── Swift / SPM (Apple platform) ───────────────────────────────────────────
platforms/apple/.build/
platforms/apple/.swiftpm/
platforms/apple/Packages/
platforms/apple/*.xcodeproj
platforms/apple/*.xcworkspace

# Built app bundle (assembled by run.sh; glob covers Finder-duplicated copies).
platforms/apple/FileID*.app/

# Test driver compiled artifact (macOS).
platforms/apple/scripts/make_bookmark

# Personal scripts hardcoded to the maintainer's NAS path / home.
platforms/apple/scripts/iterate_truenas.sh
platforms/apple/scripts/perfharness.swift
platforms/apple/scripts/deepharness.swift

# DMG build output (macOS).
platforms/apple/dist/

# ─── Rust / Cargo (Windows engine, future Linux engine) ─────────────────────
platforms/windows/src/engine/target/
platforms/linux/**/target/
**/*.rs.bk
Cargo.lock.bak

# ─── .NET / WinUI 3 (Windows app) ───────────────────────────────────────────
platforms/windows/**/bin/
platforms/windows/**/obj/
platforms/windows/**/*.user
platforms/windows/**/*.suo
platforms/windows/.vs/
platforms/windows/dist/
platforms/windows/**/AppPackages/
platforms/windows/**/BundleArtifacts/
platforms/windows/**/Generated\ Files/
platforms/windows/**/*.appx
platforms/windows/**/*.appxbundle
platforms/windows/**/*.msix
platforms/windows/**/*.msixbundle

# WiX installer build artifacts.
platforms/windows/installer/bin/
platforms/windows/installer/obj/

# Smoke harness output (regenerated each run; not source).
platforms/windows/build/smoke-out/

# Cached ONNX Runtime + DirectML NuGet downloads (regenerated by
# fetch-runtime-deps.ps1; large binaries, not source).
platforms/windows/build/runtime-cache/

# Stray dotnet build output redirected by build scripts.
platforms/windows/stderr.txt
platforms/windows/stdout.txt

# ─── IDEs ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Model weights — downloaded at runtime, never committed ─────────────────
*.safetensors
*.gguf
*.mlmodel
*.mlmodelc
*.mlpackage
*.onnx
*.pt
*.pth
*.bin
*.ckpt
*.tflite
*.weights

# Apple platform model dir.
platforms/apple/Resources/Models/
platforms/apple/Resources/**/weights/
platforms/apple/Resources/**/*.safetensors

# Windows platform model dir (weights downloaded by the Rust engine
# land in %LOCALAPPDATA%; these rules catch any strays in the tree).
# Scoped to App/installer/dist trees — NOT the engine source tree,
# where `src/engine/src/models/` is the Rust module wrapping
# ArcFace/SCRFD/MobileCLIP/VLM.
platforms/windows/src/FileID.App/**/Models/
platforms/windows/installer/**/Models/
platforms/windows/dist/**/Models/

# ─── Test corpus — auto-generated, not redistributed ────────────────────────
# macOS layout
platforms/apple/Tests/Corpus/*
!platforms/apple/Tests/Corpus/README.md
# Cross-platform layout
shared/test-corpus/files/
!shared/test-corpus/manifest.json
!shared/test-corpus/README.md

# ─── Python venv (script tooling) ───────────────────────────────────────────
.venv/

# ─── Claude Code session state + local settings ─────────────────────────────
.claude/

# ─── Zed editor personal settings ───────────────────────────────────────────
.zed/
.zed*

# ─── Local user overrides — never commit ────────────────────────────────────
*.local.json
.env
.env.local
