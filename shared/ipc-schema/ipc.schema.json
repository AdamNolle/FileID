{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fileid.local/ipc.schema.json",
  "title": "FileID IPC protocol",
  "description": "Newline-delimited JSON protocol between the FileID app and FileIDEngine. App→engine sends IPCCommand; engine→app emits IPCEvent. Wire form for the discriminated union is Swift Codable's externally-tagged shape: {\"<variantName>\": <payload>}. Empty payloads are encoded as an empty object: {\"<variantName>\": {}}. Dates are ISO8601 strings. Binary blobs are base64. JSON object keys are emitted in alphabetical order for byte-deterministic round-trips.\n\nGenerator targets: Swift (platforms/apple/shared/Sources/FileIDShared/IPCProtocol_Generated.swift), Rust (platforms/windows/src/engine/src/ipc/generated.rs), C# (platforms/windows/src/FileID.IpcSchema/Generated.cs).",
  "version": "1.0.0",

  "$defs": {
    "IPCCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "payload"],
      "properties": {
        "id": { "type": "string", "description": "App-assigned UUID; engine echoes in any reply." },
        "payload": { "$ref": "#/$defs/CommandPayload" }
      }
    },

    "IPCEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["t", "payload"],
      "properties": {
        "t":       { "type": "string", "format": "date-time", "description": "ISO8601 timestamp the engine emitted the event." },
        "payload": { "$ref": "#/$defs/EventPayload" }
      }
    },

    "CommandPayload": {
      "description": "Externally-tagged union. Exactly one key matching a variant name.",
      "oneOf": [
        {
          "type": "object",
          "required": ["startScan"],
          "additionalProperties": false,
          "properties": {
            "startScan": {
              "type": "object",
              "additionalProperties": false,
              "required": ["rootPath"],
              "properties": {
                "rootPath":    { "type": "string", "description": "Absolute filesystem path to the folder root to scan." },
                "rootDisplay": { "type": ["string", "null"], "description": "Optional human-readable label (defaults to rootPath if omitted)." },
                "rescan":      { "type": "boolean", "default": false, "description": "When true, force every file to be reprocessed even if scanned_at >= modified_unix in the DB. Default false = incremental rescan (skip already-current files)." }
              }
            }
          }
        },
        { "type": "object", "required": ["pauseScan"],          "additionalProperties": false, "properties": { "pauseScan":          { "type": "object", "additionalProperties": false } } },
        { "type": "object", "required": ["resumeScan"],         "additionalProperties": false, "properties": { "resumeScan":         { "type": "object", "additionalProperties": false } } },
        { "type": "object", "required": ["cancelScan"],         "additionalProperties": false, "properties": { "cancelScan":         { "type": "object", "additionalProperties": false } } },
        { "type": "object", "required": ["requestStatus"],      "additionalProperties": false, "properties": { "requestStatus":      { "type": "object", "additionalProperties": false } } },
        { "type": "object", "required": ["shutdown"],           "additionalProperties": false, "properties": { "shutdown":           { "type": "object", "additionalProperties": false } } },
        { "type": "object", "required": ["runFaceClustering"],  "additionalProperties": false, "properties": { "runFaceClustering":  { "type": "object", "additionalProperties": false } } },
        { "type": "object", "required": ["verifyCudaPack"],     "additionalProperties": false, "properties": { "verifyCudaPack":     { "type": "object", "additionalProperties": false, "description": "Re-probe CUDA Toolkit + cuDNN availability without restarting the engine. Engine replies with a `hardwareReprobed` event." } } },
        {
          "type": "object",
          "required": ["deepAnalyzeFile"],
          "additionalProperties": false,
          "properties": {
            "deepAnalyzeFile": {
              "type": "object",
              "additionalProperties": false,
              "required": ["fileID", "modelKind"],
              "properties": {
                "fileID":    { "type": "integer", "description": "files.id row to analyze." },
                "modelKind": { "type": "string", "description": "VLM identifier (e.g. qwen2_5_vl_3b)." }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["deepAnalyzeFolder"],
          "additionalProperties": false,
          "properties": {
            "deepAnalyzeFolder": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pathPrefix", "modelKind"],
              "properties": {
                "pathPrefix": { "type": "string", "description": "Absolute path prefix; engine matches files.path_text LIKE prefix%." },
                "modelKind":  { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["deepAnalyzeAll"],
          "additionalProperties": false,
          "properties": {
            "deepAnalyzeAll": {
              "type": "object",
              "additionalProperties": false,
              "required": ["modelKind", "skipExisting"],
              "properties": {
                "modelKind":    { "type": "string" },
                "skipExisting": { "type": "boolean", "description": "If true, skip files where vlm_description IS NOT NULL for this model." },
                "tagsOnly":     { "type": "boolean", "description": "If true, run the fast tags-only pass (one VLM call/file) instead of full caption + smart-rename + tags. Used by the background auto-tag chain. Optional; defaults to false." }
              }
            }
          }
        },
        { "type": "object", "required": ["deepAnalyzeCancel"], "additionalProperties": false, "properties": { "deepAnalyzeCancel": { "type": "object", "additionalProperties": false } } },
        {
          "type": "object",
          "required": ["prewarmModel"],
          "additionalProperties": false,
          "properties": {
            "prewarmModel": {
              "type": "object",
              "additionalProperties": false,
              "required": ["modelKind"],
              "properties": {
                "modelKind": { "type": "string", "description": "Pre-fetch a VLM's weights into the local HF cache without running inference." }
              }
            }
          }
        },
        { "type": "object", "required": ["cancelPrewarm"], "additionalProperties": false, "properties": { "cancelPrewarm": { "type": "object", "additionalProperties": false } } },

        { "type": "object", "required": ["planRestructure"], "additionalProperties": false,
          "properties": { "planRestructure": { "type": "object", "additionalProperties": false,
            "required": ["libraryRoot"],
            "properties": { "libraryRoot": { "type": "string" } } } } },

        { "type": "object", "required": ["applyRestructure"], "additionalProperties": false,
          "properties": { "applyRestructure": { "type": "object", "additionalProperties": false,
            "required": ["libraryRoot", "moves", "useSymlinks"],
            "properties": {
              "libraryRoot": { "type": "string" },
              "moves": { "type": "array", "items": {
                "type": "object", "additionalProperties": false,
                "required": ["fileID", "source", "destination", "category"],
                "properties": {
                  "fileID": { "type": "integer" },
                  "source": { "type": "string" },
                  "destination": { "type": "string" },
                  "category": { "type": "string" },
                  "tier": { "type": ["string", "null"] },
                  "confidence": { "type": "string" },
                  "reason": { "type": ["string", "null"] }
                }
              } },
              "useSymlinks": { "type": "boolean" }
            } } } },

        { "type": "object", "required": ["applyTags"], "additionalProperties": false,
          "properties": { "applyTags": { "type": "object", "additionalProperties": false,
            "required": ["fileIDs", "tags", "mode"],
            "properties": {
              "fileIDs": { "type": "array", "items": { "type": "integer" } },
              "tags": { "type": "array", "items": { "type": "string" } },
              "mode": { "type": "string", "enum": ["add", "replace", "remove"] }
            } } } },

        { "type": "object", "required": ["renameFiles"], "additionalProperties": false,
          "properties": { "renameFiles": { "type": "object", "additionalProperties": false,
            "required": ["renames"],
            "properties": {
              "renames": { "type": "array", "items": {
                "type": "object", "additionalProperties": false,
                "required": ["fileID", "newName"],
                "properties": {
                  "fileID": { "type": "integer" },
                  "newName": { "type": "string" }
                }
              } }
            } } } },

        { "type": "object", "required": ["trashFiles"], "additionalProperties": false,
          "properties": { "trashFiles": { "type": "object", "additionalProperties": false,
            "required": ["fileIDs"],
            "properties": { "fileIDs": { "type": "array", "items": { "type": "integer" } } } } } },

        { "type": "object", "required": ["mergeClusters"], "additionalProperties": false,
          "properties": { "mergeClusters": { "type": "object", "additionalProperties": false,
            "required": ["sourcePersonID", "destinationPersonID"],
            "properties": {
              "sourcePersonID": { "type": "integer" },
              "destinationPersonID": { "type": "integer" }
            } } } },

        { "type": "object", "required": ["embedTextQuery"], "additionalProperties": false,
          "properties": { "embedTextQuery": { "type": "object", "additionalProperties": false,
            "required": ["query", "queryID"],
            "properties": {
              "query": { "type": "string" },
              "queryID": { "type": "string" }
            } } } },

        { "type": "object", "required": ["renamePerson"], "additionalProperties": false,
          "properties": { "renamePerson": { "type": "object", "additionalProperties": false,
            "required": ["personID"],
            "properties": {
              "personID": { "type": "integer" },
              "title": { "type": ["string", "null"] },
              "firstName": { "type": ["string", "null"] },
              "middleName": { "type": ["string", "null"] },
              "lastName": { "type": ["string", "null"] },
              "suffix": { "type": ["string", "null"] }
            } } } },

        { "type": "object", "required": ["markPersonsAsUnknown"], "additionalProperties": false,
          "properties": { "markPersonsAsUnknown": { "type": "object", "additionalProperties": false,
            "required": ["personIDs"],
            "properties": { "personIDs": { "type": "array", "items": { "type": "integer" } } } } } },

        { "type": "object", "required": ["findMergeSuggestions"], "additionalProperties": false,
          "properties": { "findMergeSuggestions": { "type": "object", "additionalProperties": false } } },

        { "type": "object", "required": ["markPersonsDifferent"], "additionalProperties": false,
          "properties": { "markPersonsDifferent": { "type": "object", "additionalProperties": false,
            "required": ["sourcePersonID", "destinationPersonID", "sourceAnchorFaceID", "destinationAnchorFaceID"],
            "properties": {
              "sourcePersonID": { "type": "integer" },
              "destinationPersonID": { "type": "integer" },
              "sourceAnchorFaceID": { "type": "integer" },
              "destinationAnchorFaceID": { "type": "integer" }
            } } } },

        { "type": "object", "required": ["embedImageQuery"], "additionalProperties": false,
          "properties": { "embedImageQuery": { "type": "object", "additionalProperties": false,
            "required": ["fileID", "queryID"],
            "properties": {
              "fileID": { "type": "integer" },
              "queryID": { "type": "string" }
            } } } },

        { "type": "object", "required": ["restoreFromTrash"], "additionalProperties": false,
          "properties": { "restoreFromTrash": { "type": "object", "additionalProperties": false,
            "required": ["batchID"],
            "properties": { "batchID": { "type": "string" } } } } },

        { "type": "object", "required": ["revertMerge"], "additionalProperties": false,
          "properties": { "revertMerge": { "type": "object", "additionalProperties": false,
            "required": ["sourcePersonID", "destinationPersonID", "faceIDsToRevert"],
            "properties": {
              "sourcePersonID": { "type": "integer" },
              "destinationPersonID": { "type": "integer" },
              "faceIDsToRevert": { "type": "array", "items": { "type": "integer" } }
            } } } },

        { "type": "object", "required": ["wipeLibrary"], "additionalProperties": false, "properties": { "wipeLibrary": { "type": "object", "additionalProperties": false, "description": "Truncate all learned library state (tags, faces, captions, embeddings) in-process on the engine's writer connection — no file deletion, so it never races the OS file-lock. Replies with a libraryWiped event." } } }
      ]
    },

    "EventPayload": {
      "description": "Externally-tagged union. Exactly one key matching a variant name. The associated value is wrapped in {\"_0\": ...} when Swift's auto-synthesis treats the case as a single-positional argument; for cases where Swift uses named parameters, the wrapping object's keys are the parameter names directly.",
      "oneOf": [
        { "type": "object", "required": ["ready"],                   "additionalProperties": false, "properties": { "ready":                   { "$ref": "#/$defs/SinglePositional/EngineInfo" } } },
        { "type": "object", "required": ["progress"],                "additionalProperties": false, "properties": { "progress":                { "$ref": "#/$defs/SinglePositional/ScanProgress" } } },
        { "type": "object", "required": ["phaseChanged"],            "additionalProperties": false, "properties": { "phaseChanged":            { "$ref": "#/$defs/SinglePositional/ScanPhase" } } },
        {
          "type": "object",
          "required": ["discoveryComplete"],
          "additionalProperties": false,
          "properties": {
            "discoveryComplete": {
              "type": "object",
              "additionalProperties": false,
              "required": ["totalFiles"],
              "properties": { "totalFiles": { "type": "integer" } }
            }
          }
        },
        { "type": "object", "required": ["fileDone"],                "additionalProperties": false, "properties": { "fileDone":                { "$ref": "#/$defs/SinglePositional/FileDoneEvent" } } },
        { "type": "object", "required": ["batchSummary"],            "additionalProperties": false, "properties": { "batchSummary":            { "$ref": "#/$defs/SinglePositional/BatchSummary" } } },
        { "type": "object", "required": ["scanComplete"],            "additionalProperties": false, "properties": { "scanComplete":            { "$ref": "#/$defs/SinglePositional/ScanComplete" } } },
        { "type": "object", "required": ["error"],                   "additionalProperties": false, "properties": { "error":                   { "$ref": "#/$defs/SinglePositional/EngineError" } } },
        { "type": "object", "required": ["log"],                     "additionalProperties": false, "properties": { "log":                     { "$ref": "#/$defs/SinglePositional/LogLine" } } },
        { "type": "object", "required": ["faceClusteringComplete"],  "additionalProperties": false, "properties": { "faceClusteringComplete":  { "$ref": "#/$defs/SinglePositional/FaceClusteringResult" } } },
        { "type": "object", "required": ["deepAnalyzeStarting"],     "additionalProperties": false, "properties": { "deepAnalyzeStarting":     { "$ref": "#/$defs/SinglePositional/DeepAnalyzeStarting" } } },
        { "type": "object", "required": ["deepAnalyzeProgress"],     "additionalProperties": false, "properties": { "deepAnalyzeProgress":     { "$ref": "#/$defs/SinglePositional/DeepAnalyzeProgress" } } },
        { "type": "object", "required": ["deepAnalyzeFileDone"],     "additionalProperties": false, "properties": { "deepAnalyzeFileDone":     { "$ref": "#/$defs/SinglePositional/DeepAnalyzeFileDone" } } },
        { "type": "object", "required": ["deepAnalyzeComplete"],     "additionalProperties": false, "properties": { "deepAnalyzeComplete":     { "$ref": "#/$defs/SinglePositional/DeepAnalyzeComplete" } } },
        { "type": "object", "required": ["modelDownloadProgress"],   "additionalProperties": false, "properties": { "modelDownloadProgress":   { "$ref": "#/$defs/SinglePositional/ModelDownloadProgress" } } },
        { "type": "object", "required": ["queueState"],              "additionalProperties": false, "properties": { "queueState":              { "$ref": "#/$defs/SinglePositional/QueueState" } } },
        { "type": "object", "required": ["restructurePlan"],         "additionalProperties": false, "properties": { "restructurePlan":         { "$ref": "#/$defs/SinglePositional/RestructurePlan" } } },
        { "type": "object", "required": ["restructureApplyResult"],  "additionalProperties": false, "properties": { "restructureApplyResult":  { "$ref": "#/$defs/SinglePositional/RestructureApplyResult" } } },
        { "type": "object", "required": ["bulkActionResult"],        "additionalProperties": false, "properties": { "bulkActionResult":        { "$ref": "#/$defs/SinglePositional/BulkActionResult" } } },
        { "type": "object", "required": ["clipTextEmbedding"],       "additionalProperties": false, "properties": { "clipTextEmbedding":       { "$ref": "#/$defs/SinglePositional/ClipTextEmbedding" } } },
        { "type": "object", "required": ["mergeSuggestions"],        "additionalProperties": false, "properties": { "mergeSuggestions":        { "$ref": "#/$defs/SinglePositional/MergeSuggestions" } } },
        {
          "type": "object",
          "required": ["hardwareReprobed"],
          "additionalProperties": false,
          "properties": {
            "hardwareReprobed": {
              "type": "object",
              "additionalProperties": false,
              "required": ["_0"],
              "properties": {
                "_0": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["hardware"],
                  "properties": {
                    "hardware":    { "type": "object", "description": "Fresh HardwareInfo snapshot; same shape as EngineInfo.hardware." },
                    "diagnostics": { "type": ["string", "null"], "description": "Human-readable explanation when hardware.cudaPackPresent is false." }
                  }
                }
              }
            }
          }
        },
        { "type": "object", "required": ["libraryWiped"], "additionalProperties": false, "properties": { "libraryWiped": { "$ref": "#/$defs/SinglePositional/LibraryWiped" } } }
      ]
    },

    "SinglePositional": {
      "description": "Helpers for Swift's Codable auto-synthesis: a case with a single unnamed associated value encodes as {\"_0\": <encoded value>}. Each generator unwraps appropriately.",

      "EngineInfo": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["version", "pid", "workerCap", "physicalMemoryGB"],
            "properties": {
              "version":          { "type": "string" },
              "pid":              { "type": "integer", "minimum": 0, "description": "Engine process ID (Int32 on macOS; positive on all OSes for our use)." },
              "workerCap":        { "type": "integer", "minimum": 1 },
              "physicalMemoryGB": { "type": "number", "minimum": 0 },
              "hardware":         { "type": ["object", "null"], "description": "HardwareInfo snapshot — same shape as the hardwareReprobed event's hardware field. V15.9+ engines additionally populate: pCores, eCores, logicalCpuCores, workerCap, ramTotalMB, ramAvailableMB, memoryTier (low|balanced|high), vramMB, npuPresent, powerSource (ac|battery|unknown), batteryPercent, activeProfile (eco|auto|performance). Older engines omit those fields; consumers must default them." }
            }
          }
        }
      },

      "ScanProgress": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sessionID", "phase", "total", "discovered", "processed", "failed", "filesPerSecond", "residentMB", "availableMB"],
            "properties": {
              "sessionID":      { "type": "string" },
              "phase":          { "$ref": "#/$defs/ScanPhase" },
              "total":          { "type": "integer", "minimum": 0, "description": "0 until discovery completes." },
              "discovered":     { "type": "integer", "minimum": 0 },
              "processed":      { "type": "integer", "minimum": 0 },
              "failed":         { "type": "integer", "minimum": 0 },
              "filesPerSecond": { "type": "number" },
              "etaSeconds":     { "type": ["number", "null"] },
              "residentMB":     { "type": "integer", "minimum": 0 },
              "availableMB":    { "type": "integer", "minimum": 0 }
            }
          }
        }
      },

      "ScanPhase": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": { "_0": { "$ref": "#/$defs/ScanPhase" } }
      },

      "FileDoneEvent": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "kind", "totalMs", "failed"],
            "properties": {
              "path":         { "type": "string" },
              "kind":         { "type": "string", "enum": ["image", "video", "pdf", "doc", "audio", "other"] },
              "totalMs":      { "type": "number", "minimum": 0 },
              "failed":       { "type": "boolean" },
              "errorMessage": { "type": ["string", "null"] }
            }
          }
        }
      },

      "BatchSummary": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["batchIndex", "filesInBatch", "processedTotal", "wallSeconds", "filesPerSecond", "utilization", "visionP50Ms", "visionP95Ms", "clipP50Ms", "clipP95Ms", "storeInsertP50Ms", "storeInsertP95Ms", "residentMB", "availableMB"],
            "properties": {
              "batchIndex":       { "type": "integer", "minimum": 0 },
              "filesInBatch":     { "type": "integer", "minimum": 0 },
              "processedTotal":   { "type": "integer", "minimum": 0 },
              "wallSeconds":      { "type": "number", "minimum": 0 },
              "filesPerSecond":   { "type": "number" },
              "utilization":      { "type": "number", "minimum": 0, "description": "sum(workerWith) / (wallSeconds * workerCap)" },
              "visionP50Ms":      { "type": "number", "minimum": 0 },
              "visionP95Ms":      { "type": "number", "minimum": 0 },
              "clipP50Ms":        { "type": "number", "minimum": 0 },
              "clipP95Ms":        { "type": "number", "minimum": 0 },
              "storeInsertP50Ms": { "type": "number", "minimum": 0 },
              "storeInsertP95Ms": { "type": "number", "minimum": 0 },
              "residentMB":       { "type": "integer", "minimum": 0 },
              "availableMB":      { "type": "integer", "minimum": 0 }
            }
          }
        }
      },

      "ScanComplete": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sessionID", "totalFiles", "processedFiles", "failedFiles", "totalSeconds"],
            "properties": {
              "sessionID":      { "type": "string" },
              "totalFiles":     { "type": "integer", "minimum": 0 },
              "processedFiles": { "type": "integer", "minimum": 0 },
              "failedFiles":    { "type": "integer", "minimum": 0 },
              "totalSeconds":   { "type": "number", "minimum": 0 }
            }
          }
        }
      },

      "EngineError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "message"],
            "properties": {
              "kind":      { "type": "string", "description": "discovery_failed | vision_failed | db_failed | model_load_failed | model_download_failed | pack_not_available | unknown | ..." },
              "message":   { "type": "string" },
              "path":      { "type": ["string", "null"] },
              "modelKind": { "type": ["string", "null"], "description": "For errors pertaining to a specific model/pack install (e.g. mobileclip_s2, cuda_pack_x64), the model id. Lets the app route errors to the right install slot without path-string heuristics." }
            }
          }
        }
      },

      "LogLine": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["level", "message"],
            "properties": {
              "level":   { "type": "string", "enum": ["debug", "info", "warn", "error"] },
              "message": { "type": "string" }
            }
          }
        }
      },

      "FaceClusteringResult": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["personCount", "faceCount", "unmatchedFaces", "durationSeconds"],
            "properties": {
              "personCount":     { "type": "integer", "minimum": 0 },
              "faceCount":       { "type": "integer", "minimum": 0 },
              "unmatchedFaces":  { "type": "integer", "minimum": 0 },
              "durationSeconds": { "type": "number", "minimum": 0 }
            }
          }
        }
      },

      "DeepAnalyzeStarting": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["modelKind", "phase", "message"],
            "properties": {
              "modelKind": { "type": "string" },
              "phase":     { "type": "string", "enum": ["queued", "loadingModel", "resolvingTargets"] },
              "message":   { "type": "string" }
            }
          }
        }
      },

      "DeepAnalyzeProgress": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["processed", "total", "modelKind"],
            "properties": {
              "processed":   { "type": "integer", "minimum": 0 },
              "total":       { "type": "integer", "minimum": 0 },
              "etaSeconds":  { "type": ["number", "null"] },
              "currentPath": { "type": ["string", "null"] },
              "modelKind":   { "type": "string" }
            }
          }
        }
      },

      "DeepAnalyzeFileDone": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fileID", "description", "modelKind"],
            "properties": {
              "fileID":       { "type": "integer" },
              "description":  { "type": "string" },
              "proposedName": { "type": ["string", "null"] },
              "modelKind":    { "type": "string" }
            }
          }
        }
      },

      "DeepAnalyzeComplete": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["processed", "failed", "totalSeconds", "modelKind", "cancelled"],
            "properties": {
              "processed":    { "type": "integer", "minimum": 0 },
              "failed":       { "type": "integer", "minimum": 0 },
              "totalSeconds": { "type": "number", "minimum": 0 },
              "modelKind":    { "type": "string" },
              "cancelled":    { "type": "boolean" }
            }
          }
        }
      },

      "ModelDownloadProgress": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["modelKind", "fraction", "message"],
            "properties": {
              "modelKind":  { "type": "string" },
              "fraction":   { "type": "number", "minimum": 0, "maximum": 1 },
              "message":    { "type": "string" },
              "bytesDone":  { "type": ["integer", "null"], "minimum": 0 },
              "totalBytes": { "type": ["integer", "null"], "minimum": 0 }
            }
          }
        }
      },

      "QueueState": {
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pending"],
            "properties": {
              "running":          { "anyOf": [ { "type": "null" }, { "$ref": "#/$defs/QueuedJob" } ] },
              "pending":          { "type": "array", "items": { "$ref": "#/$defs/QueuedJob" } },
              "totalEtaSeconds":  { "type": ["number", "null"] }
            }
          }
        }
      },

      "RestructurePlan": {
        "description": "Engine-computed plan for re-organizing files into category folders. On macOS this is returned synchronously from planRestructure; on Windows the engine emits this event so the cross-process app can render the Sankey diagram.",
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["libraryRoot", "moves", "categoryCounts"],
            "properties": {
              "libraryRoot":           { "type": "string" },
              "moves":                 { "type": "array", "items": { "type": "object", "additionalProperties": false,
                "required": ["fileID", "source", "destination", "category"],
                "properties": {
                  "fileID":      { "type": "integer" },
                  "source":      { "type": "string" },
                  "destination": { "type": "string" },
                  "category":    { "type": "string" },
                  "tier":        { "type": ["string", "null"], "description": "V14.9 A7: per-move tier — Anchor / Mixed / Junk." },
                  "confidence":  { "type": "string", "description": "Butler confidence band — auto / review / ask (RESTRUCTURE.md §6). Empty on older engines." },
                  "reason":      { "type": ["string", "null"], "description": "Plain-language 'why filed here', shown in the drill-down." }
                }
              } },
              "categoryCounts":        { "type": "array", "items": { "type": "object", "additionalProperties": false,
                "required": ["category", "count"],
                "properties": { "category": { "type": "string" }, "count": { "type": "integer", "minimum": 0 } }
              } },
              "folderClassifications": {
                "anyOf": [
                  { "type": "null" },
                  { "type": "object", "additionalProperties": false,
                    "required": ["anchorFolders", "mixedFolders", "junkFolders"],
                    "properties": {
                      "anchorFolders": { "type": "integer", "minimum": 0 },
                      "mixedFolders":  { "type": "integer", "minimum": 0 },
                      "junkFolders":   { "type": "integer", "minimum": 0 }
                    } }
                ],
                "description": "V14.7.2: engine-authoritative folder classification counts. Null on older engines."
              }
            }
          }
        }
      },

      "RestructureApplyResult": {
        "description": "Reply to applyRestructure. applied/failed are file counts; privilegeError surfaces a 'Developer Mode required for symlinks' message when the user opted into symlink mode without SeCreateSymbolicLinkPrivilege.",
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["applied", "failed"],
            "properties": {
              "applied":        { "type": "integer", "minimum": 0 },
              "failed":         { "type": "integer", "minimum": 0 },
              "privilegeError": { "type": ["string", "null"] }
            }
          }
        }
      },

      "BulkActionResult": {
        "description": "Reply to a bulk action (applyTags / renameFiles / trashFiles / mergeClusters / renamePerson / markPersonsAsUnknown / restoreFromTrash / revertMerge). `action` is the originating command's discriminator; the trashFiles reply additionally carries the undo batch id as a ':<uuid>' suffix (e.g. 'trashFiles:5f2c…'), which UndoStack parses. messages carries per-file results.",
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action", "succeeded", "failed", "messages"],
            "properties": {
              "action":    { "type": "string", "pattern": "^(applyTags|renameFiles|trashFiles|mergeClusters|renamePerson|markPersonsAsUnknown|restoreFromTrash|revertMerge)(:[0-9a-fA-F-]+)?$" },
              "succeeded": { "type": "integer", "minimum": 0 },
              "failed":    { "type": "integer", "minimum": 0 },
              "messages":  { "type": "array", "items": { "type": "object", "additionalProperties": false,
                "required": ["ok"],
                "properties": {
                  "fileID":  { "type": ["integer", "null"] },
                  "ok":      { "type": "boolean" },
                  "message": { "type": ["string", "null"] }
                }
              } }
            }
          }
        }
      },

      "ClipTextEmbedding": {
        "description": "Reply to embedTextQuery. The app dot-products this 512-d L2-normalized float32 embedding against clip_embeddings rows to rank Library files by semantic similarity to the user's text query.",
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["queryID", "query", "embedding"],
            "properties": {
              "queryID":   { "type": "string" },
              "query":     { "type": "string" },
              "embedding": { "type": "array", "items": { "type": "number" }, "minItems": 512, "maxItems": 512 }
            }
          }
        }
      },

      "MergeSuggestions": {
        "description": "Reply to findMergeSuggestions. Each pair surfaces two person clusters that may belong to the same identity, with a similarity score and the anchor face IDs the user can preview.",
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pairs"],
            "properties": {
              "pairs": { "type": "array", "items": { "type": "object", "additionalProperties": false,
                "required": ["sourcePersonID", "destinationPersonID", "similarity", "sourceAnchorFaceID", "destinationAnchorFaceID", "sourceMemberCount", "destinationMemberCount"],
                "properties": {
                  "sourcePersonID":          { "type": "integer" },
                  "destinationPersonID":     { "type": "integer" },
                  "similarity":              { "type": "number", "minimum": 0, "maximum": 1 },
                  "sourceAnchorFaceID":      { "type": "integer" },
                  "destinationAnchorFaceID": { "type": "integer" },
                  "sourceMemberCount":       { "type": "integer", "minimum": 0 },
                  "destinationMemberCount":  { "type": "integer", "minimum": 0 }
                }
              } }
            }
          }
        }
      },

      "LibraryWiped": {
        "description": "Reply to wipeLibrary. ok=true when every table was truncated; message carries the error on failure so the app can fall back to its own wipe path.",
        "type": "object",
        "additionalProperties": false,
        "required": ["_0"],
        "properties": {
          "_0": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ok"],
            "properties": {
              "ok":      { "type": "boolean" },
              "message": { "type": ["string", "null"] }
            }
          }
        }
      }
    },

    "ScanPhase": {
      "type": "string",
      "enum": ["idle", "discovering", "tagging", "postScan", "completed", "cancelled", "failed"]
    },

    "QueuedJob": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "title"],
      "properties": {
        "id":         { "type": "string" },
        "category":   { "type": "string", "enum": ["scan", "faceCluster", "deepAnalyze"] },
        "title":      { "type": "string" },
        "etaSeconds": { "type": ["number", "null"] }
      }
    }
  },

  "type": "object",
  "description": "The wire is a sequence of newline-delimited JSON values, each conforming to either IPCCommand (app→engine) or IPCEvent (engine→app). The schema's root permits either as the canonical anchor; per-direction validation is the consumer's responsibility.",
  "oneOf": [
    { "$ref": "#/$defs/IPCCommand" },
    { "$ref": "#/$defs/IPCEvent"   }
  ]
}
