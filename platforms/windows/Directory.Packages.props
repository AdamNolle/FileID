<Project>
  <!--
    Central Package Management — every package version pinned in one place.
    csprojs use <PackageReference Include="..."/> without Version. Cargo.lock-style
    discipline: a package version change is a one-line audit-able diff.

    Update cadence: bump deliberately, document non-trivial bumps in
    shared/docs/DECISIONS.md.
  -->

  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <CentralPackageTransitivePinningEnabled>true</CentralPackageTransitivePinningEnabled>
  </PropertyGroup>

  <ItemGroup>
    <!-- Windows App SDK: the WinUI 3 runtime + bootstrapper for unpackaged apps.
         1.6 ships Mica/DesktopAcrylic system backdrops, MicaController API,
         Composition.SpringScalarNaturalMotionAnimation, AppWindowTitleBar
         dark-mode controls, and stable native AOT compatibility for libraries. -->
    <!-- WinAppSDK 1.6.241114003 had a silent XamlCompiler.exe Pass 1 bug
         on multi-XAML projects with Win2D references; 1.8 fixed Pass 1 but
         Microsoft.UI.Xaml.dll 3.1.8.0 fast-fails (0xC000027B) on Windows 11
         build 26200+. 1.7 is the sweet spot — Pass 1 works, runtime stable. -->
    <PackageVersion Include="Microsoft.WindowsAppSDK" Version="1.7.250606001" />
    <PackageVersion Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.4654" />

    <!-- Win2D for hardware-accelerated 2D — LavaLamp, Sankey, IridescentBorder. -->
    <PackageVersion Include="Microsoft.Graphics.Win2D" Version="1.3.0" />

    <!-- CsWinRT projection for WinRT APIs (Windows.Media.Ocr, etc., when called from C#). -->
    <PackageVersion Include="Microsoft.Windows.CsWinRT" Version="2.1.5" />

    <!-- System.Reactive for IObservable<IPCEvent> stream from the engine. -->
    <PackageVersion Include="System.Reactive" Version="6.0.1" />

    <!-- Read-only SQLite access from the app side. The engine owns the writer
         connection (rusqlite). Microsoft.Data.Sqlite ships native SQLite +
         FTS5 bundled, matching the engine's bundled libsqlite3 byte-for-byte. -->
    <PackageVersion Include="Microsoft.Data.Sqlite" Version="9.0.0" />

    <!-- IObservable bridge for INotifyPropertyChanged + simple LRU cache. -->
    <PackageVersion Include="Microsoft.Extensions.Caching.Memory" Version="9.0.0" />

    <!-- Test stack: xUnit + Microsoft.NET.Test.Sdk + coverlet for coverage. -->
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageVersion Include="xunit" Version="2.9.2" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageVersion Include="coverlet.collector" Version="6.0.2" />

    <!-- WiX v4 extensions used by installer/. -->
    <PackageVersion Include="WixToolset.Heat" Version="4.0.5" />
    <PackageVersion Include="WixToolset.UI.wixext" Version="4.0.5" />
    <PackageVersion Include="WixToolset.Bal.wixext" Version="4.0.5" />
    <PackageVersion Include="WixToolset.Util.wixext" Version="4.0.5" />
  </ItemGroup>
</Project>
