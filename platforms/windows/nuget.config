<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Lock down NuGet feeds. Only nuget.org. Disables any feeds the user has
    configured globally for this project tree. Improves supply-chain hygiene
    and matches the privacy posture: no surprise feeds.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!--
    Modern lockfile format. With `RestoreLockedMode` set in
    Directory.Build.props, every restore must match the committed
    packages.lock.json byte-for-byte — same posture as Cargo.lock.
  -->
  <config>
    <add key="dependencyVersion" value="Highest" />
  </config>
</configuration>
