<?xml version="1.0" encoding="UTF-8"?>
<!--
    FileIDSetup.exe — single-EXE bootstrapper bundling x64 + ARM64 MSIs.

    Architecture detection chain:
      - On x64 host (NativeMachine == AMD64 || ProcessorArchitecture == x64) → install FileID-x64.msi
      - On ARM64 host (NativeMachine == ARM64)                              → install FileID-arm64.msi
      - On x86-only or older 32-bit hosts                                   → refuse (FileID requires 64-bit)

    NativeMachine reflects the *physical* CPU even when the bootstrapper
    runs under x64 emulation on ARM64 — so an ARM64 box running the x64
    bootstrapper still installs the ARM64 MSI. WiX gives us
    `NativeMachine` as a built-in variable since v4.

    Windows version gate: 10.0.19045 (Windows 10 22H2) minimum. WinUI 3 +
    self-contained .NET 8 publishing requires it; older builds bail with
    a clear message instead of installing and failing at first launch.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle
      Name="FileID"
      Manufacturer="FileID"
      Version="$(var.Version)"
      UpgradeCode="$(var.BundleUpgradeCode)"
      AboutUrl="https://fileid.app"
      HelpUrl="https://fileid.app/help"
      Compressed="yes"
      DisableModify="yes">

    <!-- WiX v4 standard branded UI: WixStandardBootstrapperApplication
         (RTF license + Welcome/Progress/Finished pages). V14.7.3:
         LogoFile is the 130x102 letterboxed PNG generated by
         build/make-icon.ps1 from shared/docs/assets/FileID-AppIcon.png. -->
    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          LicenseFile="theme\license.rtf"
          LogoFile="theme\logo.png"
          Theme="hyperlinkLicense"
          ShowVersion="yes"
          SuppressOptionsUI="yes" />
    </BootstrapperApplication>

    <!-- Refuse to install on Win10 < 22H2 (build 19045) or earlier major
         releases. Surfaces a message in the bootstrapper UI. WiX 4 takes
         the expression in the `Condition` attribute, not the element body. -->
    <bal:Condition Condition="WindowsBuildNumber &gt;= 19045"
                   Message="FileID requires Windows 10 22H2 or newer." />

    <!-- Refuse 32-bit hosts cleanly. 43620 == 0xAA64 ==
         IMAGE_FILE_MACHINE_ARM64. -->
    <bal:Condition Condition="VersionNT64 OR NativeMachine = 43620"
                   Message="FileID requires a 64-bit edition of Windows." />

    <Chain>
      <!-- Rollback boundary: a standalone checkpoint at the head of the
           chain. On a failed install, Burn only unwinds packages installed
           AFTER the most recent boundary — packages committed before it stay
           put. With exactly one MSI chained today this is belt-and-suspenders,
           but it's the correct place to declare it (RollbackBoundary is a
           Chain construct, not an MSI/Package one) and future-proofs the chain
           for prerequisite packages (e.g. the WinAppSDK runtime ExePackage the
           app csproj notes it depends on). Transaction="no" keeps each MSI's
           own atomic Windows Installer transaction rather than wrapping the
           whole chain in one MSI transaction. -->
      <RollbackBoundary Id="InstallStart" Vital="yes" Transaction="no" />

      <!-- x64 MSI: install on AMD64. NativeMachine 34404 (0x8664) ==
           IMAGE_FILE_MACHINE_AMD64. -->
      <MsiPackage
          Id="FileIDx64"
          SourceFile="$(var.MsiX64Path)"
          Compressed="yes"
          Visible="no"
          InstallCondition="NativeMachine = 34404 OR (VersionNT64 AND NOT NativeMachine = 43620)" />

      <!-- ARM64 MSI. -->
      <MsiPackage
          Id="FileIDarm64"
          SourceFile="$(var.MsiArm64Path)"
          Compressed="yes"
          Visible="no"
          InstallCondition="NativeMachine = 43620" />
    </Chain>
  </Bundle>
</Wix>
