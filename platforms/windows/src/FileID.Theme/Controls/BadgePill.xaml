<?xml version="1.0" encoding="utf-8"?>
<!--
    BadgePill — small color-tinted capsule for inline labels. Mirror of
    macOS Theme.BadgePill (Theme.swift:71). 10pt semibold colored text on
    a 15%-opaque tinted capsule.

    Usage:
        <theme:BadgePill Label="ON-DEVICE" Accent="{StaticResource AiBrush}" />
-->
<UserControl
    x:Class="FileID.Theme.Controls.BadgePill"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border x:Name="PillRoot"
            CornerRadius="100"
            Padding="8,3,8,3"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <TextBlock x:Name="LabelText"
                   FontSize="{StaticResource FontSizeBadge}"
                   FontWeight="SemiBold" />
    </Border>
</UserControl>
