<?xml version="1.0" encoding="utf-8"?>
<!--
    Generic.xaml — auto-discovered ControlTemplate location for templated
    controls in this assembly. WinUI loads templates from
    ms-appx:///FileID.Theme/Themes/Generic.xaml at first use of each
    templated control.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:FileID.Theme.Controls"
    xmlns:motion="using:FileID.Theme.Motion"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    xmlns:win2d="using:Microsoft.Graphics.Canvas.UI.Xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///FileID.Theme/Theme.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="controls:GlassCard">
        <Setter Property="Padding" Value="{StaticResource PaddingM}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusM}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:GlassCard">
                    <Grid>
                        <Border CornerRadius="{TemplateBinding CornerRadius}">
                            <Border.Background>
                                <media:AcrylicBrush TintColor="#000000" TintOpacity="0.5" TintLuminosityOpacity="0.65" FallbackColor="#1A1A1A" />
                            </Border.Background>
                        </Border>
                        <Border Background="{ThemeResource SurfaceCardBrush}" CornerRadius="{TemplateBinding CornerRadius}" />
                        <Border BorderBrush="{ThemeResource SurfaceBorderBrush}" BorderThickness="1" CornerRadius="{TemplateBinding CornerRadius}" />
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTransitions="{TemplateBinding ContentTransitions}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            Padding="{TemplateBinding Padding}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="motion:IridescentBorder">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="motion:IridescentBorder">
                    <win2d:CanvasControl x:Name="PART_Canvas" ClearColor="Transparent" IsHitTestVisible="False" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LavaLampBackground (V14.6) draws via Microsoft.UI.Composition
         directly — no Win2D, no template part needed. The default style
         just enforces that the control is hit-transparent. -->
    <Style TargetType="motion:LavaLampBackground">
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <!--
        ThemedSegmentedControl ItemTemplate uses {Binding} (not {x:Bind}).
        x:Bind requires compile-time type resolution; SegmentedOption is in
        the same assembly as this template, so Pass 1 silently fails on the
        forward reference. Plain Binding is runtime-resolved and works.
    -->
    <Style TargetType="controls:ThemedSegmentedControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ThemedSegmentedControl">
                    <Grid Padding="3"
                          CornerRadius="20"
                          Background="{ThemeResource WhiteSubtleFillBrush}"
                          BorderBrush="{ThemeResource WhiteSubtleStrokeBrush}"
                          BorderThickness="1">
                        <ItemsRepeater ItemsSource="{TemplateBinding ItemsSource}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="2" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Content="{Binding Label}"
                                        Tag="{Binding Tag}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="12,6"
                                        FontSize="{StaticResource FontSizeBody}"
                                        FontWeight="Medium"
                                        Foreground="#B3FFFFFF"
                                        CornerRadius="20" />
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
