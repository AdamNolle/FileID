<?xml version="1.0" encoding="utf-8"?>
<!--
    ShortcutsCheatSheet — modal-friendly help view listing every
    keyboard shortcut. Triggered from MainWindow's F1 / Ctrl+? handlers.
-->
<UserControl
    x:Class="FileID.Views.ShortcutsCheatSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    MinWidth="420">

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">
        <StackPanel Spacing="20" Padding="4,4,12,4">

            <StackPanel Spacing="6">
                <TextBlock Text="NAVIGATION"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold"
                           CharacterSpacing="40"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <Grid ColumnSpacing="14" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0"
                            Padding="8,3"
                            CornerRadius="6"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="Alt + 1..6" Style="{StaticResource CaptionTextBlockStyle}"
                                   FontFamily="Cascadia Mono, Consolas" />
                    </Border>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Jump to tab (Library / People / Cleanup / Deep Analyze / Restructure / Settings)"
                               Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" TextWrapping="Wrap" />

                    <Border Grid.Row="1" Grid.Column="0" Padding="8,3" CornerRadius="6"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="Ctrl + Shift + S" Style="{StaticResource CaptionTextBlockStyle}"
                                   FontFamily="Cascadia Mono, Consolas" />
                    </Border>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Toggle sidebar"
                               Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />

                    <Border Grid.Row="2" Grid.Column="0" Padding="8,3" CornerRadius="6"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="Ctrl + F" Style="{StaticResource CaptionTextBlockStyle}"
                                   FontFamily="Cascadia Mono, Consolas" />
                    </Border>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Focus the Library search bar"
                               Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />

                    <Border Grid.Row="3" Grid.Column="0" Padding="8,3" CornerRadius="6"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="F1" Style="{StaticResource CaptionTextBlockStyle}"
                                   FontFamily="Cascadia Mono, Consolas" />
                    </Border>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Show this cheat sheet"
                               Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />

                    <Border Grid.Row="4" Grid.Column="0" Padding="8,3" CornerRadius="6"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="Esc" Style="{StaticResource CaptionTextBlockStyle}"
                                   FontFamily="Cascadia Mono, Consolas" />
                    </Border>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Close any open modal"
                               Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="LIBRARY ACTIONS"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold"
                           CharacterSpacing="40"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <Grid ColumnSpacing="14" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Padding="8,3" CornerRadius="6"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="Ctrl + O" Style="{StaticResource CaptionTextBlockStyle}"
                                   FontFamily="Cascadia Mono, Consolas" />
                    </Border>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Pick a folder for the library"
                               Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />

                    <Border Grid.Row="1" Grid.Column="0" Padding="8,3" CornerRadius="6"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="Ctrl + R" Style="{StaticResource CaptionTextBlockStyle}"
                                   FontFamily="Cascadia Mono, Consolas" />
                    </Border>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Start (or rescan) the library"
                               Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />

                    <Border Grid.Row="2" Grid.Column="0" Padding="8,3" CornerRadius="6"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                            HorizontalAlignment="Left">
                        <TextBlock Text="Right-click" Style="{StaticResource CaptionTextBlockStyle}"
                                   FontFamily="Cascadia Mono, Consolas" />
                    </Border>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Open / Show in Explorer / Copy path on any tile"
                               Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" TextWrapping="Wrap" />
                </Grid>
            </StackPanel>

            <Border Padding="14,10"
                    CornerRadius="10"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                <TextBlock TextWrapping="Wrap"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="You can also drag a folder onto the FileID window to start scanning it." />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
