<?xml version="1.0" encoding="utf-8"?>
<!--
    CleanupView — duplicate-group list with keeper selection.

-->
<UserControl
    x:Class="FileID.Views.Cleanup.CleanupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FileID.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32,32,32,24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Cleanup" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="Visually-similar files grouped by perceptual hash. Trashed items stay recoverable."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
            <ScrollViewer Grid.Column="1"
                          HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Click="OnTrashNonKeepersClicked"
                            ToolTipService.ToolTip="Move every non-keeper duplicate to the Recycle Bin.">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon FontSize="13" Glyph="&#xE74D;" />
                            <TextBlock Text="Trash non-keepers" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnRefreshClicked"
                            ToolTipService.ToolTip="Re-scan the database for duplicate phash groups.">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon FontSize="13" Glyph="&#xE72C;" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:DuplicateGroup">
                        <Grid CornerRadius="12"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              Padding="16"
                              Tag="{x:Bind PerceptualHash}"
                              RightTapped="OnGroupRightTapped">
                            <!-- Per-group right-click action menu.
                                 RightTapped seeds the current-group cache so
                                 MenuFlyoutItem clicks (which don't inherit
                                 DataContext on WinUI 3) can resolve to the
                                 correct DuplicateGroup. -->
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Keep first"
                                                    Click="OnGroupKeepFirst"
                                                    ToolTipService.ToolTip="Mark only the first member as keeper.">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE73E;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Keep largest"
                                                    Click="OnGroupKeepLargest"
                                                    ToolTipService.ToolTip="Mark the largest file as keeper.">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8AB;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Invert keeper"
                                                    Click="OnGroupInvert"
                                                    ToolTipService.ToolTip="Pick the next member as keeper.">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE72C;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Skip group"
                                                    Click="OnGroupSkip"
                                                    ToolTipService.ToolTip="Exclude this group from 'Trash non-keepers'.">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE894;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Unskip group"
                                                    Click="OnGroupUnskip"
                                                    ToolTipService.ToolTip="Re-include this group in 'Trash non-keepers'.">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE73E;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Trash this group only"
                                                    Click="OnGroupTrashNow"
                                                    ToolTipService.ToolTip="Move every non-keeper member to the Recycle Bin.">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE74D;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Bind Caption, Mode=OneWay}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <ItemsRepeater ItemsSource="{x:Bind Members}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Vertical" Spacing="4"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:DuplicateMember">
                                            <Grid ColumnSpacing="10" Padding="6,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <RadioButton GroupName="{x:Bind GroupKey, Mode=OneTime}"
                                                             IsChecked="{x:Bind IsKeeper, Mode=TwoWay}"
                                                             Content="Keep"
                                                             VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Path}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{x:Bind SizeDisplay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="12"
                    Visibility="{x:Bind FooterVisibility, Mode=OneWay}">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="16" Height="16"/>
            <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
