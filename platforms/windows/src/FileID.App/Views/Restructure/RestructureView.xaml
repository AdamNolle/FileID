<?xml version="1.0" encoding="utf-8"?>
<!--
    RestructureView — plan + apply UI.

    Plan: button → engine planRestructure IPC → category-summary list.
    Apply: floating bar → engine applyRestructure IPC → result count.
    Sankey (pure-XAML via Path/BezierSegment, no Win2D) renders source-
    folder → category ribbons; TreeDiff renders side-by-side current vs.
    proposed trees. Both feed off the same engine plan; the
    VisualizationModeCombo flips between them.
-->
<UserControl
    x:Class="FileID.Views.Restructure.RestructureView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FileID.ViewModels"
    xmlns:r="using:FileID.Views.Restructure"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="r:SankeyFlowControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="r:SankeyFlowControl">
                        <Canvas x:Name="PART_Canvas" Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="r:TreeDiffControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="r:TreeDiffControl">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="Current"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontWeight="SemiBold" />
                                <TreeView x:Name="PART_CurrentTree" Grid.Row="1" />
                            </Grid>
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="Proposed"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource GoldBrush}"
                                           FontWeight="SemiBold" />
                                <TreeView x:Name="PART_ProposedTree" Grid.Row="1" />
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Padding="32,32,32,24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Restructure" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock TextWrapping="Wrap"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Plan a folder reorganization. Photos by year/month, videos by year, documents flat. Preview as symlinks first; commit as moves when you're happy."/>
            <!-- Deep Analyze hint banner. macOS RestructureView surfaces
                 this whenever Deep Analyze has produced captions but the
                 user hasn't named people yet — the restructure layout's
                 People/ bucket reads "Person N" instead of "Alice" without
                 names. Tap-through routes to People. -->
            <Border x:Name="DeepAnalyzeHintBanner"
                    Visibility="Collapsed"
                    CornerRadius="10"
                    Padding="12,10"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource AiBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE77B;" FontSize="14"
                              Foreground="{ThemeResource AiBrush}"
                              VerticalAlignment="Top" Margin="0,1,0,0" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="Name your people first so the People/ folders are organized by real names instead of 'Person 1'." />
                    <Button Grid.Column="2" Content="Open People"
                            Click="OnOpenPeopleHintClicked" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="14">
                <Border CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Plan summary" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock x:Name="PlanStatusText"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Text="No plan generated yet. Click Generate plan to compute the proposed reorganization for your library."/>
                        <!-- FEAT-CRIT-3: three-tier classifier headline.
                             Anchor folders (kept intact), Mixed folders (kept,
                             outliers extracted), Junk folders (dissolved).
                             Computed from per-source-folder move ratios. -->
                        <Grid x:Name="ClassifierStrip"
                              Visibility="Collapsed"
                              ColumnSpacing="12"
                              Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Padding="14,12"
                                    CornerRadius="8"
                                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                    BorderBrush="{ThemeResource GoldBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="AnchorCountText"
                                               Text="0"
                                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="Anchor folders"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="Kept intact"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Padding="14,12"
                                    CornerRadius="8"
                                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                    BorderBrush="{ThemeResource AiBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="MixedCountText"
                                               Text="0"
                                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="Mixed folders"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="Outliers extracted"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2"
                                    Padding="14,12"
                                    CornerRadius="8"
                                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                    BorderBrush="{ThemeResource DestructiveBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="JunkCountText"
                                               Text="0"
                                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="Junk folders"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="Dissolved"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- Butler confidence tiers (RESTRUCTURE.md §6): auto-file
                             the sure moves, one-click review the medium ones, hold
                             the unsure. Toggling a chip includes/excludes that tier
                             from Apply — the default holds the "ask" tier back. -->
                        <StackPanel x:Name="ConfidenceStrip" Visibility="Collapsed" Spacing="6" Margin="0,4,0,0">
                            <TextBlock Text="What to apply"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ToggleButton x:Name="AutoTierToggle" IsChecked="True" Click="OnTierToggle"
                                              Padding="14,8" CornerRadius="8"
                                              ToolTipService.ToolTip="High-confidence placements — safe to auto-file (still fully reversible).">
                                    <StackPanel Spacing="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="#6CC24A" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="AutoTierCount" Text="0" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBlock Text="Auto-file" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="ReviewTierToggle" IsChecked="True" Click="OnTierToggle"
                                              Padding="14,8" CornerRadius="8"
                                              ToolTipService.ToolTip="Medium confidence — worth a one-click look before applying.">
                                    <StackPanel Spacing="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="#FFCC00" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="ReviewTierCount" Text="0" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBlock Text="Review" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="AskTierToggle" IsChecked="False" Click="OnTierToggle"
                                              Padding="14,8" CornerRadius="8"
                                              ToolTipService.ToolTip="Low confidence — held back by default; include to apply these too.">
                                    <StackPanel Spacing="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="#F5B74D" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="AskTierCount" Text="0" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBlock Text="Hold" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </ToggleButton>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="GeneratePlanButton"
                                Content="Generate plan"
                                Click="OnPlanClicked"
                                Style="{StaticResource GoldButtonStyle}"
                                Height="40"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <Border x:Name="SankeyCard"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="20"
                        Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="VisualizationHeader"
                                       Text="Source folder → category flow"
                                       Style="{StaticResource SubtitleTextBlockStyle}" />
                            <ComboBox Grid.Column="1"
                                      x:Name="VisualizationModeCombo"
                                      Width="180"
                                      SelectionChanged="OnVisualizationModeChanged"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Sankey ribbons" Tag="sankey" />
                                <ComboBoxItem Content="Tree diff"      Tag="tree"   />
                            </ComboBox>
                        </Grid>
                        <r:SankeyFlowControl x:Name="Sankey" Height="320" />
                        <r:TreeDiffControl x:Name="TreeDiff" Height="320" Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border x:Name="CategoryListCard"
                        CornerRadius="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="20"
                        Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock Text="By category" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <ItemsRepeater x:Name="CategoryRepeater">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:RestructureCategoryRow">
                                    <Grid Padding="14,10"
                                          CornerRadius="8"
                                          Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind CategoryDisplay}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind CountDisplay}"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   Foreground="{ThemeResource GoldBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- floating ApplyBar — port of macOS RestructureApplyBar.swift.
             Frosted Acrylic backdrop, selection summary on the left, two-step
             chip flow in the middle, gold-gradient primary + outline secondary
             on the right. Springs at response 0.28 / dampingFraction 0.7 on
             button hover via SpringScalarNaturalMotionAnimation. -->
        <Border Grid.Row="2"
                CornerRadius="16"
                BorderBrush="{ThemeResource GoldDimBrush}"
                BorderThickness="1">
            <Border.Background>
                <AcrylicBrush
                    TintColor="Black"
                    TintOpacity="0.55"
                    TintLuminosityOpacity="0.30"
                    FallbackColor="#1A1A1A" />
            </Border.Background>
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid Padding="18,14" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>     <!-- selection summary -->
                    <ColumnDefinition Width="Auto"/>     <!-- divider -->
                    <ColumnDefinition Width="Auto"/>     <!-- step chips -->
                    <ColumnDefinition Width="*"/>       <!-- spacer / status text -->
                    <ColumnDefinition Width="Auto"/>     <!-- secondary button -->
                    <ColumnDefinition Width="Auto"/>     <!-- primary button -->
                </Grid.ColumnDefinitions>

                <!-- Selection summary -->
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                        <TextBlock x:Name="ApplyBarSelectedCount"
                                   Text="0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource GoldBrush}" />
                        <TextBlock Text="of"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Bottom" />
                        <TextBlock x:Name="ApplyBarTotalCount"
                                   Text="0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Bottom" />
                        <TextBlock Text="selected"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Bottom" />
                    </StackPanel>
                    <TextBlock x:Name="ApplyBarHint"
                               Text="Generate a plan to enable Apply."
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="240" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="1"
                        Height="32"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Opacity="0.4"
                        VerticalAlignment="Center"
                        Margin="2,0,0,0"/>

                <!-- Two-step chips: 1. Shortcuts (filled when canApply) → 2. Real moves -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border x:Name="StepChip1Bg"
                                Width="20" Height="20"
                                CornerRadius="10"
                                Background="{ThemeResource GoldBrush}">
                            <TextBlock Text="1"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="Black"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="0">
                            <TextBlock Text="Apply as shortcuts"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Safe preview"
                                       FontSize="9"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <FontIcon Glyph="&#xE72A;"
                              FontSize="11"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border x:Name="StepChip2Bg"
                                Width="20" Height="20"
                                CornerRadius="10"
                                Background="Transparent"
                                BorderBrush="{ThemeResource GoldDimBrush}"
                                BorderThickness="1">
                            <TextBlock Text="2"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource GoldBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="0">
                            <TextBlock Text="Convert to real moves"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="When ready"
                                       FontSize="9"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Status / spacer -->
                <TextBlock Grid.Column="3"
                           x:Name="ApplyStatusText"
                           Text=""
                           VerticalAlignment="Center"
                           TextAlignment="Right"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="12,0,12,0"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis" />

                <!-- Secondary: outline gold "Convert to real moves" -->
                <Button x:Name="ApplyMovesButton"
                        Grid.Column="4"
                        IsEnabled="False"
                        Click="OnApplyMovesClicked"
                        Background="Transparent"
                        BorderBrush="{ThemeResource GoldDimBrush}"
                        BorderThickness="1"
                        Padding="14,8"
                        CornerRadius="10"
                        Margin="0,0,8,0"
                        ToolTipService.ToolTip="Move files to their proposed destinations. Recoverable via Ctrl+Z (one undo step)."
                        AutomationProperties.Name="Apply restructure as real moves">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8AB;" FontSize="13" Foreground="{ThemeResource GoldBrush}" />
                        <TextBlock Text="Convert to real moves" Foreground="{ThemeResource GoldBrush}" />
                    </StackPanel>
                </Button>

                <!-- Primary: gold-gradient "Apply as shortcuts (N)" -->
                <Button x:Name="ApplySymlinkButton"
                        Grid.Column="5"
                        IsEnabled="False"
                        Click="OnApplySymlinksClicked"
                        Padding="16,9"
                        CornerRadius="10"
                        ToolTipService.ToolTip="Lay down symlinks instead of moving files. Reversible — delete the symlinked tree to undo."
                        AutomationProperties.Name="Preview restructure as symlinks">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="{ThemeResource ApplyBarGoldStopColor}" />
                            <GradientStop Offset="1" Color="{ThemeResource ApplyBarOrangeStopColor}" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.BorderBrush>
                        <SolidColorBrush Color="Transparent" />
                    </Button.BorderBrush>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71B;" FontSize="13" Foreground="Black" />
                        <TextBlock x:Name="ApplySymlinkButtonText"
                                   Text="Apply as shortcuts"
                                   FontWeight="SemiBold"
                                   Foreground="Black" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

    </Grid>
</UserControl>
