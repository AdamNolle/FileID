<?xml version="1.0" encoding="utf-8"?>
<!--
    PeopleView — face cluster cards in a wrap layout.

    Mirror of macOS People/PeopleView.swift. Cards show the cluster's
    anchor face crop + a caption. Phase 3 cut: card grid + load on tab
    activation. Phase 3.x adds drag-merge + person-detail sheet.
-->
<UserControl
    x:Class="FileID.Views.People.PeopleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FileID.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32,32,32,24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="People" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="Faces clustered into named cards. Drag to merge."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
            <!-- V14.7.4: header action buttons in a horizontal-scroll
                 wrapper so on narrow windows they scroll instead of
                 overflowing the title's * column. -->
            <ScrollViewer Grid.Column="1"
                          HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="SelectButton"
                        Click="OnToggleSelectMode"
                        ToolTipService.ToolTip="Multi-select clusters for bulk merge / mark-as-unknown.">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon FontSize="13" Glyph="&#xE762;" />
                        <TextBlock x:Name="SelectButtonText" Text="Select" />
                    </StackPanel>
                </Button>
                <Button x:Name="SuggestedMergesButton"
                        Click="OnSuggestedMergesClicked"
                        ToolTipService.ToolTip="Find pairs of clusters that might be the same person.">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <!-- V14.9-E1: sparkle glyph mirrors macOS sparkles SF Symbol;
                             previously a link icon (E8B6) which read as "merge",
                             not "AI suggestion". -->
                        <FontIcon FontSize="13" Glyph="&#xE945;" Foreground="{ThemeResource AiBrush}" />
                        <TextBlock Text="Suggested merges" />
                    </StackPanel>
                </Button>
                <Button x:Name="RefreshButton"
                        Click="OnRefreshClicked"
                        ToolTipService.ToolTip="Re-cluster faces using current ArcFace embeddings.">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon FontSize="13" Glyph="&#xE72C;" />
                        <TextBlock Text="Re-cluster" />
                    </StackPanel>
                </Button>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- FEAT-CRIT-1: bulk-action toolbar, only visible in select mode. -->
        <Grid x:Name="BulkActionBar"
              Grid.Row="2"
              Visibility="Collapsed"
              Padding="16,12"
              CornerRadius="12"
              BorderBrush="{ThemeResource GoldBrush}"
              BorderThickness="1"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="BulkSelectionText"
                       Text="0 selected"
                       VerticalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Button Grid.Column="1"
                    x:Name="BulkMergeButton"
                    Margin="0,0,8,0"
                    Click="OnBulkMergeClicked"
                    ToolTipService.ToolTip="Merge every selected cluster into the first selected one."
                    AutomationProperties.Name="Merge selected clusters into one">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="13" Glyph="&#xE8B6;" />
                    <TextBlock Text="Merge into one" />
                </StackPanel>
            </Button>
            <Button Grid.Column="2"
                    x:Name="BulkUnknownButton"
                    Margin="0,0,8,0"
                    Click="OnBulkMarkUnknownClicked"
                    ToolTipService.ToolTip="Mark every selected cluster as Unknown (clears name + flags is_unknown)."
                    AutomationProperties.Name="Mark selected clusters as unknown">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="13" Glyph="&#xE894;" />
                    <TextBlock Text="Mark as unknown" />
                </StackPanel>
            </Button>
            <Button Grid.Column="3"
                    Click="OnToggleSelectMode"
                    ToolTipService.ToolTip="Exit select mode."
                    AutomationProperties.Name="Exit select mode">
                <TextBlock Text="Done" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Clusters, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="180"
                                       MinItemHeight="220"
                                       MinRowSpacing="12"
                                       MinColumnSpacing="12"
                                       ItemsStretch="Fill"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:PersonCluster">
                        <Grid CornerRadius="12"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              Padding="12"
                              Tag="{x:Bind ClusterId}"
                              CanDrag="True"
                              AllowDrop="True"
                              DragStarting="OnClusterDragStarting"
                              DragOver="OnClusterDragOver"
                              DragLeave="OnClusterDragLeave"
                              Drop="OnClusterDrop"
                              DoubleTapped="OnClusterDoubleTapped">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Edit name + faces"
                                                    Click="OnContextOpenDetails"
                                                    Tag="{x:Bind ClusterId}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE70F;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Find merge candidates"
                                                    Click="OnContextSuggestedMerges">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE945;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                    CornerRadius="100"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Width="120" Height="120">
                                <Image Source="{x:Bind AnchorImage, Mode=OneTime}"
                                       Stretch="UniformToFill"
                                       Width="120" Height="120" />
                            </Border>
                            <TextBlock Grid.Row="1"
                                       Text="{x:Bind Caption}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <!-- FEAT-CRIT-1: per-card selection checkbox.
                                 Visibility driven from PeopleView code-behind
                                 (UpdateSelectionVisibility on each Loaded). -->
                            <CheckBox Grid.Row="0"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      MinWidth="0"
                                      Margin="-6,-6,0,0"
                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                      Tag="select-cb"
                                      AutomationProperties.Name="Select cluster" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Spacing="12"
                    Visibility="{x:Bind FooterVisibility, Mode=OneWay}">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="16" Height="16"/>
            <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
