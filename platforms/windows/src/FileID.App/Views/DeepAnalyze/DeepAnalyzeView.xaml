<?xml version="1.0" encoding="utf-8"?>
<!--
    DeepAnalyzeView — VLM picker + library run controls.

    Mirror of macOS DeepAnalyze/DeepAnalyzeView.swift. Lists the four
    shippable VLMs (Qwen2.5-VL 3B/7B, Gemma 3 4B, SmolVLM) with disk +
    RAM budgets, an install button, then a per-library or per-file run
    control. Phase 6 cut: model picker + placeholder run controls;
    Phase 6.x wires the IPC `prewarmModel` + `deepAnalyzeAll` round-trips.
-->
<UserControl
    x:Class="FileID.Views.DeepAnalyze.DeepAnalyzeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="32,28,32,32" Spacing="20" MaxWidth="820" HorizontalAlignment="Stretch">

            <StackPanel Spacing="4">
                <TextBlock Text="Deep Analyze" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock TextWrapping="Wrap"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Run a local vision-language model on every image to generate captions and smart names. Whole library, on-device, no cloud calls. Pick one model — switch any time."/>
            </StackPanel>

            <!-- Qwen 7B (recommended) -->
            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="Qwen2.5-VL 7B (recommended)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="≈4.5 GB disk · ≈7.5 GB GPU/RAM at runtime · Q4_K_M quant"/>
                    <Button Content="Install"
                            Click="OnInstallClicked"
                            Tag="qwen2.5-vl-7b"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Qwen 3B (lighter) -->
            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="Qwen2.5-VL 3B" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="≈1.9 GB disk · ≈3.5 GB GPU/RAM · faster, lower fidelity"/>
                    <Button Content="Install"
                            Click="OnInstallClicked"
                            Tag="qwen2.5-vl-3b"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Gemma 3 4B -->
            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="Gemma 3 4B" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="≈2.5 GB disk · ≈4.5 GB GPU/RAM · alternative VLM"/>
                    <Button Content="Install"
                            Click="OnInstallClicked"
                            Tag="gemma-3-4b"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- SmolVLM -->
            <Border CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="SmolVLM 256M" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="≈700 MB disk · &lt;1 GB GPU/RAM · tiny + CPU-friendly"/>
                    <Button Content="Install"
                            Click="OnInstallClicked"
                            Tag="smolvlm"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       TextWrapping="Wrap"
                       Text="Models live in %LOCALAPPDATA%\FileID\Models\VLM\ — uninstall by deleting the folder."/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
