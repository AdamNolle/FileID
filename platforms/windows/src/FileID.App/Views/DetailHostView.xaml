<?xml version="1.0" encoding="utf-8"?>
<!--
    DetailHostView — the right-hand pane. Switches between the active tab's
    view and the onboarding splash when no folder is picked.

    Tab crossfade animation (0.22s easeInOut) is a future polish item.
    For now: snap.
-->
<UserControl
    x:Class="FileID.Views.DetailHostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:FileID.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Host">
        <!-- Code-behind swaps Host's child based on AppViewModel.HasFolder
             + AppViewModel.ActiveTab. Initial child loaded in OnLoaded. -->
    </Grid>
</UserControl>
