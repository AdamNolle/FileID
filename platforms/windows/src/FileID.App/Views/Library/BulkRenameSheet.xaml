<?xml version="1.0" encoding="utf-8"?>
<!--
    BulkRenameSheet — preview + edit a batch rename plan. Each row shows
    the current filename + a TextBox seeded with the proposed name.
    Toggling the checkbox excludes a row from the apply.
-->
<UserControl
    x:Class="FileID.Views.Library.BulkRenameSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    MinWidth="640"
    MinHeight="420">

    <Grid RowSpacing="12" Padding="4,4,4,4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock x:Name="HeaderText"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Text="Rename selected files" />
            <TextBlock x:Name="SelectionText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsRepeater x:Name="RenameRepeater">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="6" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
