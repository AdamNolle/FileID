<?xml version="1.0" encoding="utf-8"?>
<!--
    LibraryView — search bar + kind filter + thumbnail grid.

 Same visual hierarchy:
      - Top toolbar: search box (Ctrl+F focus), kind segmented control
      - Grid: ItemsRepeater + UniformGridLayout, 256-px tiles
      - Empty state: when no rows match the current query/filter

-->
<UserControl
    x:Class="FileID.Views.Library.LibraryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FileID.ViewModels"
    xmlns:motion="using:FileID.Theme.Motion"
    xmlns:theme="using:FileID.Theme.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- macOS Library binds Cmd+F to search-box focus, Esc to "clear
         selection / clear search", Cmd+A to select-all, Cmd+Z to undo
         the last destructive op. Mirror with Ctrl on Windows. The
         accelerators are scoped to the UserControl so they fire from
         anywhere on the page, not only from the search box. -->
    <UserControl.KeyboardAccelerators>
        <KeyboardAccelerator Modifiers="Control" Key="F" Invoked="OnFocusSearchAccelerator" />
        <KeyboardAccelerator Modifiers="Control" Key="A" Invoked="OnSelectAllAccelerator" />
        <KeyboardAccelerator Modifiers="Control" Key="Z" Invoked="OnUndoAccelerator" />
        <KeyboardAccelerator Key="Escape" Invoked="OnEscapeAccelerator" />
    </UserControl.KeyboardAccelerators>

    <Grid Padding="32,32,32,24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Library" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Search across filenames, OCR text, and CLIP semantic embeddings."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Toolbar: search + kind filter + Select-all-visible + Undo pill. -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     Height="36"
                     PlaceholderText="Search filenames + OCR text — Ctrl+F"
                     TextChanged="OnSearchChanged"/>

            <ComboBox x:Name="KindFilter"
                      Grid.Column="1"
                      Width="160"
                      SelectionChanged="OnKindChanged"
                      SelectedIndex="0">
                <ComboBoxItem Content="All kinds" Tag="all"/>
                <ComboBoxItem Content="Images" Tag="image"/>
                <ComboBoxItem Content="Videos" Tag="video"/>
                <ComboBoxItem Content="Documents" Tag="doc"/>
                <ComboBoxItem Content="PDFs" Tag="pdf"/>
                <ComboBoxItem Content="Audio" Tag="audio"/>
            </ComboBox>

            <!-- explicit "Select all" affordance. macOS Library
                 tab always exposes this so users don't have to discover
                 Ctrl+Click. Toggling fills the selection bar; clicking
                 again clears. -->
            <Button x:Name="SelectAllButton"
                    Grid.Column="2"
                    Click="OnSelectAllClicked"
                    ToolTipService.ToolTip="Select all visible files (Ctrl+A)">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE762;" FontSize="13" />
                    <TextBlock x:Name="SelectAllText" Text="Select" />
                </StackPanel>
            </Button>

            <!-- Undo-last-rename header button. Hidden when the
                 UndoStack is empty; shows a tappable pill with the last
                 destructive op's label when entries exist. -->
            <Button x:Name="UndoButton"
                    Grid.Column="3"
                    Click="OnUndoLastClicked"
                    Visibility="Collapsed"
                    ToolTipService.ToolTip="Undo last destructive action (Ctrl+Z)">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE7A7;" FontSize="13" />
                    <TextBlock x:Name="UndoButtonText" Text="Undo" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Inline banners: CLIP-not-installed hint when the user types
             a semantic query, Deep Analyze active banner when the engine
             is captioning, face clustering banner when clustering is
             running. Mirrors macOS LibraryView's banner stack. Collapses
             cleanly when no banner applies. -->
        <StackPanel Grid.Row="2" Spacing="6">
            <Border x:Name="ClipMissingBanner"
                    Visibility="Collapsed"
                    CornerRadius="10"
                    Padding="12,10"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource AiBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="14"
                              Foreground="{ThemeResource AiBrush}"
                              VerticalAlignment="Top" Margin="0,1,0,0" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="Install MobileCLIP for semantic image search — your typed words can match what's in each photo, not just the filename." />
                    <Button Grid.Column="2" Content="Install" Click="OnInstallClipFromBannerClicked" VerticalAlignment="Center" />
                </Grid>
            </Border>
            <!-- Scene Classifier missing banner. Shown when the
                 ImageNet-1k classifier model isn't installed AND there are
                 image files in the Library. Without the classifier, tagging
                 falls back to enriched-extras only — users see "Has Location"
                 / "iPhone" / "Year_2024" instead of "Dog" / "Beach" / "Food".
                 ~22 MB download; small enough that we also auto-install on
                 first launch via ClassifierAutoInstaller, but the banner
                 covers users who launch before auto-install completes or
                 who opted out of the auto path. -->
            <Border x:Name="ClassifierMissingBanner"
                    Visibility="Collapsed"
                    CornerRadius="10"
                    Padding="12,10"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource GoldBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE8C1;" FontSize="14"
                              Foreground="{ThemeResource GoldBrush}"
                              VerticalAlignment="Top" Margin="0,1,0,0" />
                    <TextBlock Grid.Column="1" TextWrapping="Wrap"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="Install the Scene Classifier for AI tags — automatically labels photos with 1000 categories like 'Dog', 'Beach', 'Document'. ~22 MB." />
                    <Button Grid.Column="2" Content="Install" Click="OnInstallClassifierFromBannerClicked" VerticalAlignment="Center" />
                </Grid>
            </Border>
            <Border x:Name="DeepAnalyzeBanner"
                    Visibility="Collapsed"
                    CornerRadius="10"
                    Padding="12,10"
                    Background="{ThemeResource GoldSelectedBackgroundBrush}"
                    BorderBrush="{ThemeResource GoldBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ProgressRing Grid.Column="0" IsActive="True" Width="16" Height="16"
                                  Foreground="{ThemeResource GoldBrush}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               x:Name="DeepAnalyzeBannerText"
                               VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               Text="Deep Analyze running…" />
                </Grid>
            </Border>
            <Border x:Name="FaceClusteringBanner"
                    Visibility="Collapsed"
                    CornerRadius="10"
                    Padding="12,10"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource AiBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ProgressRing Grid.Column="0" IsActive="True" Width="16" Height="16"
                                  Foreground="{ThemeResource AiBrush}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="Grouping faces into people clusters…" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Selection toolbar — visible when at least one tile is selected. -->
        <Grid Grid.Row="3"
              x:Name="SelectionBar"
              Visibility="Collapsed"
              ColumnSpacing="10"
              Padding="14,10"
              CornerRadius="10"
              Background="{ThemeResource AccentFillColorTertiaryBrush}"
              BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
              BorderThickness="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="SelectionCountText"
                       VerticalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Button Grid.Column="1" Click="OnTagSelectedClicked"
                    ToolTipService.ToolTip="Apply tags to selected files">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8EC;" FontSize="13"/>
                    <TextBlock Text="Tag…"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Click="OnRenameSelectedClicked"
                    ToolTipService.ToolTip="Rename selected files">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8AC;" FontSize="13"/>
                    <TextBlock Text="Rename…"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Click="OnTrashSelectedClicked"
                    ToolTipService.ToolTip="Move selected files to the Recycle Bin">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                    <TextBlock Text="Trash…"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="4" Click="OnClearSelectionClicked"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTipService.ToolTip="Clear selection (Esc)"
                    AutomationProperties.Name="Clear selection">
                <FontIcon Glyph="&#xE894;" FontSize="13"/>
            </Button>
        </Grid>

        <!-- Grid of tiles. -->
        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      ZoomMode="Disabled">
            <ItemsRepeater x:Name="Repeater"
                           ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                           ElementPrepared="OnRepeaterElementPrepared"
                           ElementClearing="OnRepeaterElementClearing">
                <!-- Square tiles. UniformGridLayout cells are 180 wide minimum;
                     each tile binds its own Height = ActualWidth + 68 (caption row)
                     via IdentityDouble, so the image area is always 1:1. macOS
                     uses .aspectRatio(1, contentMode: .fit) for the same effect.
                     ItemsStretch="Fill" keeps the cells filling the grid width;
                     MinItemHeight=248 (180+68) reserves a square-friendly cell. -->
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="180"
                                       MinItemHeight="248"
                                       MinRowSpacing="12"
                                       MinColumnSpacing="12"
                                       ItemsStretch="Fill"/>
                </ItemsRepeater.Layout>

                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:FileTile">
                        <!-- PointerEntered/Exited drive a spring
                             scale (1.012, response 0.18s) matching macOS
                             LibraryView.swift:681-682 hover affordance.
                             Height = ActualWidth + 68 (caption row) so the
                             image area is exactly square regardless of how
                             long the caption is. Mirrors macOS's
                             .aspectRatio(1, contentMode: .fit) pattern. -->
                        <Grid x:Name="TileRoot"
                              CornerRadius="12"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              Padding="12"
                              Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}, Converter={StaticResource IdentityDouble}, ConverterParameter=68}"
                              Tag="{x:Bind Path}"
                              Tapped="OnTileTapped"
                              RightTapped="OnTileRightTapped"
                              DoubleTapped="OnTileDoubleTapped"
                              CanDrag="True"
                              DragStarting="OnTileDragStarting"
                              PointerEntered="OnTilePointerEntered"
                              PointerExited="OnTilePointerExited"
                              ToolTipService.ToolTip="{x:Bind Path}">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Open"
                                                    Click="OnContextOpen"
                                                    Tag="{x:Bind Path}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8E5;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Show in Explorer"
                                                    Click="OnContextReveal"
                                                    Tag="{x:Bind Path}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE838;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Find similar"
                                                    Click="OnContextFindSimilar"
                                                    Tag="{x:Bind Id}"
                                                    ToolTipService.ToolTip="Search for visually similar images via CLIP">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE721;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="Copy path"
                                                    Click="OnContextCopyPath"
                                                    Tag="{x:Bind Path}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8C8;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <!-- Row 0 = image (square; takes remaining height
                                 = TileRoot.ActualWidth). Row 1 = caption,
                                 pinned at exactly 68 DIP so a long filename
                                 or extra tag chip can't push the image
                                 area taller than its neighbours. -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="68"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                    CornerRadius="8">
                                <Grid>
                                    <!-- Shimmer placeholder while
                                         thumbnail loads. Visibility tied to
                                         Thumbnail null-ness via converter. -->
                                    <motion:ShimmerView
                                        Visibility="{x:Bind Thumbnail, Mode=OneWay, Converter={StaticResource NullToVisibility}}"/>
                                    <!-- Initial Opacity is 1 to guarantee the tile is
                                         visible as soon as the BitmapImage is bound. The
                                         shimmer overlay's NullToVisibility converter is
                                         the load indicator. OnTileImageOpened still fires
                                         the spring fade for the macOS-parity visual when
                                         the bitmap arrives (start at 0 inside the handler,
                                         spring to 1) — if for any reason it doesn't fire,
                                         the user still sees the rendered tile. -->
                                    <Image Source="{x:Bind Thumbnail, Mode=OneWay}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           ImageOpened="OnTileImageOpened" />
                                </Grid>
                            </Border>
                            <Border Grid.Row="0"
                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                    BorderThickness="3"
                                    CornerRadius="8"
                                    Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                            <FontIcon Grid.Row="0"
                                      Glyph="&#xE73E;"
                                      FontSize="22"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      Margin="0,4,4,0"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                      Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                            <!-- Hover badges: kind + face cluster + OCR text indicators top-left.
                                 Kind badge first so the "what is this file" answer reads
                                 left-to-right even when face/OCR badges are absent. -->
                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Spacing="4"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="4,4,0,0">
                                <Border Padding="4,2"
                                        CornerRadius="4"
                                        Background="{ThemeResource TileScrimBrush}"
                                        ToolTipService.ToolTip="{x:Bind KindDisplay}">
                                    <FontIcon Glyph="{x:Bind KindBadgeGlyph}" FontSize="12" Foreground="White" />
                                </Border>
                                <Border Padding="4,2"
                                        CornerRadius="4"
                                        Background="{ThemeResource TileScrimBrush}"
                                        Visibility="{x:Bind HasFaces, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon Glyph="&#xE77B;" FontSize="12" Foreground="{ThemeResource GoldBrush}" />
                                </Border>
                                <Border Padding="4,2"
                                        CornerRadius="4"
                                        Background="{ThemeResource TileScrimBrush}"
                                        Visibility="{x:Bind HasText, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon Glyph="&#xE8C1;" FontSize="12" Foreground="{ThemeResource AiBrush}" />
                                </Border>
                            </StackPanel>
                            <!-- Caption stack pinned at fixed 68 DIP. Overflow
                                 is clipped by the Grid's row constraint; long
                                 filenames + chip rows + size still fit. -->
                            <StackPanel Grid.Row="1" Spacing="2" Margin="0,8,0,0"
                                        VerticalAlignment="Top">
                                <TextBlock Text="{x:Bind FileName}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Deep Analyze smart-rename proposal. Gold text per
                                     macOS visual language; collapses when the engine
                                     hasn't proposed a rename. ToolTip echoes the
                                     proposal so truncated text remains discoverable. -->
                                <TextBlock Text="{x:Bind ProposedName, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource GoldBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{x:Bind HasProposedName, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                           ToolTipService.ToolTip="{x:Bind ProposedName, Mode=OneWay}" />
                                <!-- Auto-tag chips. Bound to FileTile.TopTwoTags
                                     (already prefix(2)-sliced server-side so we
                                     don't allocate per layout pass). Visibility
                                     collapses cleanly when Tags is empty so the
                                     card height stays the same as before. -->
                                <ItemsControl ItemsSource="{x:Bind TopTwoTags, Mode=OneWay}"
                                              Visibility="{x:Bind HasTags, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <theme:TagChip TagText="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{x:Bind SizeDisplay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Status footer: loading + error. -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    Spacing="12"
                    Visibility="{x:Bind FooterVisibility, Mode=OneWay}">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="16" Height="16"/>
            <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
