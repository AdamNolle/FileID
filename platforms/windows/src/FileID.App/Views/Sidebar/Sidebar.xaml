<?xml version="1.0" encoding="utf-8"?>
<!--
    Sidebar — composition root. 260 DIP fixed width. Hosts:
      • SidebarFolderHeader     (folder picker + change/clear/wipe actions)
      • SidebarTabList          (the six tab buttons)
      • SidebarProcessingControl (Start Scan / Pause / Resume / Cancel + ETA + stats)
      • SidebarPipelineProgress  (5-stage Scan→Tag→People→Captions→Done dots)
      • SidebarQueueList        (pending jobs)
      • SidebarEngineStatus     (engine PID/version/RAM tooltip + state pill)
-->
<UserControl
    x:Class="FileID.Views.Sidebar.Sidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileID.Views.Sidebar"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- V14.7.4: rows 0-4 live inside a ScrollViewer so on short windows
         the queue list overflows scrollably instead of pushing the engine
         pill (the most important "is the engine running" indicator) below
         the visible area. The engine pill stays anchored at row 1 of the
         outer Grid where Height="Auto" means it always renders.

         16-px outer padding + 16-px row spacing matches Fluent's 8-px
         baseline grid. The bottom padding is doubled (24-px) so the
         engine pill never touches the window edge. -->
    <Grid Padding="16,12,16,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />    <!-- Scrollable content -->
            <RowDefinition Height="Auto" /> <!-- Engine status (anchored) -->
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      ZoomMode="Disabled">
            <StackPanel Spacing="16">
                <local:SidebarFolderHeader />
                <local:SidebarTabList />
                <local:SidebarProcessingControl />
                <local:SidebarPipelineProgress />
                <local:SidebarQueueList />
            </StackPanel>
        </ScrollViewer>

        <!-- Engine status anchored at the bottom — always visible. -->
        <local:SidebarEngineStatus Grid.Row="1" Margin="0,16,0,0" />
    </Grid>
</UserControl>
