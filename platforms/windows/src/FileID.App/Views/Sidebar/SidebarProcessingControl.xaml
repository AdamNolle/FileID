<?xml version="1.0" encoding="utf-8"?>
<!--
    SidebarProcessingControl — Start Scan / Pause / Resume / Cancel + ETA
    + 4-stat grid (discovered / tagged / memory MB / failures).

    Three states:
      • Pre-scan: idle pill + "Start Scan" gold button (Ctrl+R).
      • In-flight: phase badge + progress bar + stat grid + Pause/Cancel.
      • Completed: summary line + Rescan button.

    All FontIcon glyphs use numeric XML escapes so the bytes survive
    encoding pipelines.
-->
<UserControl
    x:Class="FileID.Views.Sidebar.SidebarProcessingControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="10">
        <!-- Non-fatal engine events: skipped stages, partial discovery,
             stale-WAL warning, CUDA fall-back. Distinct from LastError
             so a later per-file error can't clobber the banner. -->
        <Grid x:Name="WarningBanner"
              Visibility="Collapsed"
              Padding="12,9"
              CornerRadius="8"
              Background="{StaticResource GoldSelectedBackgroundBrush}"
              BorderBrush="{StaticResource GoldBrush}"
              BorderThickness="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0"
                      Glyph="&#xE7BA;"
                      FontSize="14"
                      Margin="0,2,8,0"
                      Foreground="{StaticResource GoldBrush}"
                      VerticalAlignment="Top" />
            <TextBlock Grid.Column="1"
                       x:Name="WarningBannerText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />
            <Button Grid.Column="2"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6,2"
                    Click="OnDismissWarningClicked"
                    ToolTipService.ToolTip="Dismiss"
                    AutomationProperties.Name="Dismiss warning">
                <FontIcon Glyph="&#xE711;" FontSize="11" />
            </Button>
        </Grid>

        <!-- AutoPilot tracker removed. macOS has no separate
             AutoPilot UI; the standard SidebarPipelineProgress (Scan →
             Tag → People → Captions → Done) already covers the full
             pipeline, and Start Scan now auto-advances into face
             clustering exactly like macOS does (see EngineClient.Apply's
             ScanCompleteEvent handler). -->

        <!-- Section header — uppercase muted caption, Fluent Settings pattern. -->
        <TextBlock Text="PROCESSING"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   FontWeight="SemiBold"
                   CharacterSpacing="40"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   AutomationProperties.HeadingLevel="Level2" />

        <!-- Pre-scan: idle pill + Start Scan -->
        <StackPanel x:Name="IdlePanel" Spacing="8">
            <Grid Padding="12,9"
                  CornerRadius="8"
                  BorderThickness="1"
                  BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                  Background="{ThemeResource ControlFillColorDefaultBrush}">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE916;" FontSize="14" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock x:Name="IdleStatusText"
                               Text="Idle. Pick a folder to begin."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
            <Button x:Name="StartScanButton"
                    HorizontalAlignment="Stretch"
                    Click="OnStartScanClicked"
                    Style="{StaticResource GoldButtonStyle}"
                    Height="40"
                    AccessKey="R"
                    ToolTipService.ToolTip="Start scan (Ctrl+R)"
                    AutomationProperties.Name="Start Scan"
                    AutomationProperties.HelpText="Start scanning the selected folder (Ctrl+R)">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon FontSize="13" Glyph="&#xE768;" />
                    <TextBlock Text="Start Scan" FontWeight="SemiBold" />
                </StackPanel>
            </Button>
            <!-- AutoPilot button removed. macOS has only "Start Scan"
                 and the engine auto-enqueues face clustering after scan
                 completes. Windows now matches: ScanComplete in
                 EngineClient.Apply auto-fires RunFaceClusteringAsync.
                 Deep Analyze stays manual (user must name ≥1 person first),
                 also matching macOS. -->

            <!-- tiny "Open engine log" affordance. Useful diagnostic
                 link when a scan didn't behave as expected. Opens
                 %LOCALAPPDATA%\FileID\logs\engine.jsonl in the user's default
                 .jsonl handler (Notepad on a fresh box). Single-click; no
                 prominence — sits as a discreet caption-styled hyperlink. -->
            <HyperlinkButton x:Name="OpenLogButton"
                             Click="OnOpenLogClicked"
                             Padding="0"
                             HorizontalAlignment="Left"
                             AutomationProperties.Name="Open engine log"
                             AutomationProperties.HelpText="Open the engine diagnostic log in your default viewer">
                <TextBlock Text="Open engine log"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </HyperlinkButton>
        </StackPanel>

        <!-- In-flight: phase + progress + stats + Pause/Cancel -->
        <StackPanel x:Name="ScanningPanel" Spacing="10" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon x:Name="PhaseIcon" Glyph="&#xE895;" FontSize="13" Foreground="{ThemeResource GoldBrush}" />
                <TextBlock x:Name="PhaseText"
                           Text="Discovering…"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
            </StackPanel>

            <ProgressBar x:Name="ScanProgressBar"
                         IsIndeterminate="False"
                         Maximum="100"
                         Value="0"
                         Foreground="{ThemeResource GoldBrush}" />

            <Grid ColumnSpacing="6" RowSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Padding="10,8"
                        x:Name="DiscoveredStatBorder"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8"
                        AutomationProperties.Name="Discovered">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Discovered"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="StatDiscovered" Text="—"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{ThemeResource GoldBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Padding="10,8"
                        x:Name="TaggedStatBorder"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8"
                        AutomationProperties.Name="Tagged">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Tagged"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="StatTagged" Text="—"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{ThemeResource GoldBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Padding="10,8"
                        x:Name="MemoryStatBorder"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8"
                        AutomationProperties.Name="Memory">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Memory"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="StatMemory" Text="—"
                                   FontSize="15" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Padding="10,8"
                        x:Name="FailuresStatBorder"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8"
                        AutomationProperties.Name="Failures">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Failures"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="StatFailures" Text="0"
                                   FontSize="15" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="EtaText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="ETA: —" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="PauseResumeButton" Grid.Column="0"
                        Click="OnPauseResumeClicked"
                        HorizontalAlignment="Stretch"
                        Padding="12,8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="8">
                    <TextBlock x:Name="PauseResumeText"
                               Text="Pause"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </Button>
                <Button Grid.Column="1"
                        Click="OnCancelClicked"
                        HorizontalAlignment="Stretch"
                        Padding="12,8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource DestructiveBorderBrush}"
                        Background="{ThemeResource DestructiveBackgroundBrush}"
                        CornerRadius="8"
                        AutomationProperties.Name="Cancel scan">
                    <TextBlock Text="Cancel"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource DestructiveTextBrush}" />
                </Button>
            </Grid>
        </StackPanel>

        <!-- Completed: Rescan -->
        <StackPanel x:Name="CompletedPanel" Spacing="8" Visibility="Collapsed">
            <TextBlock x:Name="CompletedSummary"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" />
            <Button HorizontalAlignment="Stretch"
                    Click="OnStartScanClicked"
                    Height="40"
                    Style="{StaticResource GoldButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon FontSize="13" Glyph="&#xE72C;" />
                    <TextBlock Text="Rescan" FontWeight="SemiBold" />
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
